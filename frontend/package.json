{
  "name": "uscornie-frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host",
    "build": "vue-tsc --noEmit && vite build",
    "preview": "vite preview",
    "type-check": "vue-tsc --noEmit",
    "lint": "pnpm oxlint ./src",
    "fmt": "pnpm oxfmt ./src",
    "fmt:check": "pnpm oxfmt --check ./src",
    "test": "vitest",
    "test:run": "vitest run"
  },
  "dependencies": {
    "@oxfmt/binding-linux-arm64-musl": "^0.51.0",
    "@oxlint/binding-linux-arm64-musl": "^1.66.0",
    "axios": "^1.4.0",
    "pinia": "^3.0.4",
    "vue": "^3.3.4",
    "vue-router": "^4.2.4"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "@types/vue": "^2.0.0",
    "@vitejs/plugin-vue": "^4.2.3",
    "@vue/test-utils": "^2.4.5",
    "autoprefixer": "^10.4.14",
    "happy-dom": "^14.7.1",
    "oxfmt": "latest",
    "oxlint": "latest",
    "postcss": "^8.4.27",
    "tailwindcss": "^3.3.3",
    "typescript": "^6.0.3",
    "vite": "^4.4.5",
    "vitest": "^1.5.0",
    "vue-tsc": "^3.3.1"
  }
}
